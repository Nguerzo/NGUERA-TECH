# Base de données (Supabase → Project Settings → Database → Connect)
# Pooler transaction-mode (pgbouncer) — utilisé à l'exécution par Prisma Client
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:6543/postgres?pgbouncer=true"
# Pooler session-mode — utilisé uniquement par `prisma migrate` (advisory locks)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:5432/postgres"

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..." # clé publique, exposée au navigateur
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..." # jamais exposée au navigateur, réservée aux écritures serveur (phase 4+)

# --- Phase 4 : formulaire de contact / capture de prospects ---

# Resend (resend.com → API Keys). Clé serveur uniquement, jamais NEXT_PUBLIC_.
RESEND_API_KEY="re_..."

# Adresse d'envoi. Doit appartenir à un domaine vérifié dans Resend
# (resend.com → Domains) avant la mise en production. En développement, vous
# pouvez utiliser le domaine sandbox de Resend : "onboarding@resend.dev".
RESEND_FROM_EMAIL="TO_BE_REPLACED_WITH_YOUR_VERIFIED_SENDER@your-domain.com"

# Adresse qui reçoit la notification interne à chaque nouveau prospect.
# Remplacez par une vraie adresse avant la mise en production — aucune valeur
# par défaut n'est fournie intentionnellement.
ADMIN_NOTIFICATION_EMAIL="TO_BE_REPLACED_WITH_YOUR_ADMIN_EMAIL@your-domain.com"

# Sel utilisé pour hacher les adresses IP avant stockage (rate limiting /
# anti-spam) — l'IP en clair n'est jamais écrite en base. Générez une valeur
# aléatoire unique par environnement, ex. `openssl rand -hex 32`.
IP_HASH_SALT="CHANGE_ME_TO_A_RANDOM_SECRET"
