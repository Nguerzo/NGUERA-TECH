# Base de données (Supabase → Project Settings → Database → Connect)
# Pooler transaction-mode (pgbouncer) — utilisé à l'exécution par Prisma Client
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:6543/postgres?pgbouncer=true"
# Pooler session-mode — utilisé uniquement par `prisma migrate` (advisory locks)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:5432/postgres"

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..." # clé publique, exposée au navigateur
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..." # jamais exposée au navigateur, réservée aux écritures serveur (phase 4+)
