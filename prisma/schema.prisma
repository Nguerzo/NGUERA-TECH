// Schéma Prisma — phase 3 (auth + espace client en lecture seule)
// Les modèles Ticket, Message, Quote, BlogPost, AuditLog du document d'architecture
// seront ajoutés en phase 4/5. On démarre volontairement avec le socle minimal
// nécessaire pour que le dashboard client affiche des données réelles.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooler transaction-mode (pgbouncer) — requêtes à l'exécution
  directUrl = env("DIRECT_URL")   // pooler session-mode — migrations (advisory locks incompatibles avec pgbouncer)
}

enum Role {
  CLIENT
  TEAM
  ADMIN
}

enum ProjectStatus {
  ANALYSE
  DEVELOPPEMENT
  TESTS
  LIVRAISON
  MAINTENANCE
}

enum InvoiceStatus {
  BROUILLON
  ENVOYEE
  PAYEE
  EN_RETARD
}

// Miroir de la table auth.users de Supabase : Supabase gère le mot de passe
// et la session, ce modèle stocke les données métier liées à l'utilisateur.
// L'id doit être identique à auth.users.id (voir README, section "Provisioning").
model User {
  id          String    @id // = auth.users.id (Supabase)
  email       String    @unique
  fullName    String
  role        Role      @default(CLIENT)
  companyName String?
  phone       String?
  createdAt   DateTime  @default(now())
  projects    Project[]
  invoices    Invoice[]

  // Portail interne (phase 5)
  leadActivities    LeadActivity[]
  leadAttachments   LeadAttachment[]
  convertedFromLead Lead?            @relation("LeadConvertedClient")
  quotes            Quote[]          @relation("QuoteClient")
  quotesCreated     Quote[]          @relation("QuoteCreatedBy")
}

model Project {
  id            String        @id @default(uuid())
  title         String
  description   String
  status        ProjectStatus @default(ANALYSE)
  client        User          @relation(fields: [clientId], references: [id])
  clientId      String
  budgetEstime  Decimal?
  dateDebut     DateTime?
  dateLivraison DateTime?
  documents     Document[]
  invoices      Invoice[]
  quotes        Quote[]
  createdAt     DateTime      @default(now())

  @@index([clientId])
}

enum QuoteStatus {
  BROUILLON
  ENVOYE
  ACCEPTE
  REFUSE
  EXPIRE
}

model Quote {
  id          String      @id @default(uuid())
  number      String      @unique
  client      User        @relation("QuoteClient", fields: [clientId], references: [id])
  clientId    String
  project     Project?    @relation(fields: [projectId], references: [id])
  projectId   String?
  status      QuoteStatus @default(BROUILLON)
  currency    String      @default("GBP")
  validUntil  DateTime?
  notes       String?
  items       QuoteItem[]
  createdBy   User        @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([clientId])
}

model QuoteItem {
  id          String  @id @default(uuid())
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId     String
  description String
  quantity    Decimal @default(1)
  unitPrice   Decimal
  position    Int     @default(0)

  @@index([quoteId])
}

model Invoice {
  id        String        @id @default(uuid())
  number    String        @unique
  project   Project       @relation(fields: [projectId], references: [id])
  projectId String
  client    User          @relation(fields: [clientId], references: [id])
  clientId  String
  amount    Decimal
  currency  String        @default("XOF")
  status    InvoiceStatus @default(BROUILLON)
  dueDate   DateTime
  paidAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([clientId])
}

model Document {
  id         String   @id @default(uuid())
  project    Project  @relation(fields: [projectId], references: [id])
  projectId  String
  fileName   String
  fileUrl    String
  uploadedBy String
  createdAt  DateTime @default(now())

  @@index([projectId])
}

// Phase 4 — capture des prospects (formulaire de contact public).
// Écrit uniquement depuis app/actions/lead.ts (Server Action, clé DATABASE_URL
// côté serveur) — jamais depuis le navigateur.
// Phase 5 (portail interne) : pipeline CRM complet — voir LeadActivity/LeadAttachment.
enum LeadStatus {
  NOUVEAU
  CONTACTE
  QUALIFIE
  PROPOSITION_ENVOYEE
  NEGOCIATION
  GAGNE
  PERDU
}

enum LeadLocale {
  en
  fr
}

model Lead {
  id                 String     @id @default(uuid())
  fullName           String
  company            String?
  email              String
  phone              String?
  country            String?
  service            String?
  projectDescription String?
  budget             String?
  currency           String?
  timeline           String?
  contactPreference  String?
  gdprConsent        Boolean    @default(false)
  marketingConsent   Boolean    @default(false)
  locale             LeadLocale @default(en)
  source             String     @default("website_contact_form")
  status             LeadStatus @default(NOUVEAU)
  confirmationEmailSentAt DateTime?
  adminNotifiedAt    DateTime?
  convertedClientId  String?    @unique
  convertedClient    User?      @relation("LeadConvertedClient", fields: [convertedClientId], references: [id])
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  activities  LeadActivity[]
  attachments LeadAttachment[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

enum LeadActivityType {
  NOTE
  STATUS_CHANGE
  ATTACHMENT
}

// Historique unifié d'un prospect : notes manuelles + changements de statut +
// ajouts de pièces jointes, dans l'ordre chronologique — une seule timeline
// à afficher plutôt que plusieurs listes séparées.
model LeadActivity {
  id        String           @id @default(uuid())
  lead      Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String
  type      LeadActivityType
  content   String?
  oldStatus LeadStatus?
  newStatus LeadStatus?
  author    User             @relation(fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime         @default(now())

  @@index([leadId, createdAt])
}

// Fichiers liés à un prospect (devis reçu, brief, pièce d'identité pour la
// conformité...). Stockage réel dans le bucket Supabase Storage
// "lead-attachments" — cette table ne garde que les métadonnées.
model LeadAttachment {
  id           String   @id @default(uuid())
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId       String
  fileName     String
  filePath     String
  fileSize     Int
  contentType  String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  uploadedById String
  createdAt    DateTime @default(now())

  @@index([leadId])
}

// Journal de toutes les tentatives de soumission (réussies ou non) — sert au
// rate limiting (comptage par ipHash) et à la traçabilité des erreurs/spam.
// L'IP n'est jamais stockée en clair : ipHash = sha256(ip + salt).
model ContactAttempt {
  id        String   @id @default(uuid())
  ipHash    String
  email     String?
  outcome   String   // success | duplicate | rate_limited | spam | validation_error | server_error | email_error
  detail    String?
  createdAt DateTime @default(now())

  @@index([ipHash, createdAt])
  @@index([email, createdAt])
}
